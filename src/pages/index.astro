---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allEntries = await getCollection('entries');

// Chronological grouping (existing behavior)
const byDate = [...allEntries].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const groupedByYear: { year: number; entries: typeof allEntries }[] = [];
for (const entry of byDate) {
  const year = entry.data.date.getUTCFullYear();
  const existing = groupedByYear.find(g => g.year === year);
  if (existing) existing.entries.push(entry);
  else groupedByYear.push({ year, entries: [entry] });
}

// Alphabetical grouping with article-aware sort
// Strip leading "The ", "A ", "An " for sort key; capture the article for display
function articleSplit(title: string): { sortKey: string; article: string | null; rest: string } {
  const m = title.match(/^(The|A|An)\s+(.+)$/i);
  if (m) return { sortKey: m[2].toLowerCase(), article: m[1], rest: m[2] };
  return { sortKey: title.toLowerCase(), article: null, rest: title };
}

const byName = [...allEntries].sort((a, b) => {
  const ka = articleSplit(a.data.title).sortKey;
  const kb = articleSplit(b.data.title).sortKey;
  return ka.localeCompare(kb);
});

const groupedByLetter: { letter: string; entries: typeof allEntries }[] = [];
for (const entry of byName) {
  const { sortKey } = articleSplit(entry.data.title);
  const letter = sortKey.charAt(0).toUpperCase();
  const display = /[A-Z]/.test(letter) ? letter : '#';
  const existing = groupedByLetter.find(g => g.letter === display);
  if (existing) existing.entries.push(entry);
  else groupedByLetter.push({ letter: display, entries: [entry] });
}

// Type counts for filter chips
const typeCounts: Record<string, number> = { Phrase: 0, Event: 0, Iconography: 0, Document: 0 };
for (const entry of allEntries) {
  const t = entry.data.type;
  if (t in typeCounts) typeCounts[t]++;
}

// Date formatters: short for date sort, year for alphabetical sort
const formatDateShort = (date: Date) => new Intl.DateTimeFormat('en-US', {
  month: 'short', day: 'numeric', timeZone: 'UTC'
}).format(date);
const formatDateMonthYear = (date: Date) => new Intl.DateTimeFormat('en-US', {
  month: 'short', year: 'numeric', timeZone: 'UTC'
}).format(date);

// Build a slug -> stripped-lowercase-body map for client-side full-text search
const bodyTextBySlug: Record<string, string> = {};
for (const entry of allEntries) {
  const raw = entry.body || '';
  const stripped = raw
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]*`/g, ' ')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
    .replace(/[#>*_~`]+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .toLowerCase();
  bodyTextBySlug[entry.slug] = stripped;
}
---
<BaseLayout>
  <section style="margin-bottom: 24px;">
    <h1 style="font-family: var(--display); font-size: clamp(40px, 4.4vw, 56px); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500; margin-bottom: 14px;">
      An annotated archive of bitcoin&apos;s <em style="font-style: italic; color: var(--orange); font-weight: 400;">cultural artifacts.</em>
    </h1>
    <p style="font-family: var(--display); font-style: italic; font-size: 20px; color: var(--ink-mid); margin-bottom: 18px; text-wrap: balance;">
      A small editorial board. Each artifact researched, sourced, dated, annotated.
    </p>
    <hr style="margin-top: 28px; border: 0; border-top: 1px solid var(--ink-mid); opacity: 0.2;" />
  </section>

  <div class="search-row">
    <input
      type="search"
      id="catalog-search"
      class="catalog-search-input"
      placeholder={`SEARCH ${allEntries.length} ARTIFACTS`}
      autocomplete="off"
      spellcheck="false"
    />
    <span class="search-count" id="search-count" aria-live="polite"></span>
    <span class="sort-toggle" role="group" aria-label="Sort order">
      <span class="lbl">Sort:</span><button type="button" class="opt active" data-sort="date">Date</button><button type="button" class="opt" data-sort="name">Name</button>
    </span>
  </div>

  <nav class="filter-row" aria-label="Filter catalog by type">
    <a href="?type=all" class="filter-chip" data-type="all">ALL <span class="count">{allEntries.length}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=phrase" class="filter-chip" data-type="phrase">PHRASE <span class="count">{typeCounts.Phrase}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=event" class="filter-chip" data-type="event">EVENT <span class="count">{typeCounts.Event}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=iconography" class="filter-chip" data-type="iconography">ICONOGRAPHY <span class="count">{typeCounts.Iconography}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=document" class="filter-chip" data-type="document">DOCUMENT <span class="count">{typeCounts.Document}</span></a>
  </nav>

  <div class="index-list sort-mode active" data-sort-mode="date">
    {groupedByYear.map((group) => (
      <>
        <div class="era-divider">{group.year}</div>
        {group.entries.map((entry) => (
          <a href={`/entries/${entry.slug}`} class="index-row" data-search={`${entry.data.title} ${entry.data.deck || ''} ${bodyTextBySlug[entry.slug] || ''}`.toLowerCase()}>
            <span class="id">{formatDateShort(entry.data.date)}</span>
            <span class="title">{entry.data.title}</span>
            <span class="era">{entry.data.type}</span>
            <span class="status">{entry.data.foundational ? '★' : ''}</span>
          </a>
        ))}
      </>
    ))}
  </div>

  <div class="index-list sort-mode" data-sort-mode="name">
    {groupedByLetter.map((group) => (
      <>
        <div class="letter-divider">{group.letter}</div>
        {group.entries.map((entry) => {
          const split = articleSplit(entry.data.title);
          return (
            <a href={`/entries/${entry.slug}`} class="index-row" data-search={`${entry.data.title} ${entry.data.deck || ''} ${bodyTextBySlug[entry.slug] || ''}`.toLowerCase()}>
              <span class="id">{formatDateMonthYear(entry.data.date)}</span>
              <span class="title">
                {split.article ? (
                  <>{split.rest}, <span class="article">{split.article}</span></>
                ) : (
                  <>{entry.data.title}</>
                )}
              </span>
              <span class="era">{entry.data.type}</span>
              <span class="status">{entry.data.foundational ? '★' : ''}</span>
            </a>
          );
        })}
      </>
    ))}
  </div>

  <footer class="entry-footer" style="margin-top: 80px;">
    <span>{allEntries.length} entries · refreshed weekly</span>
    <span>bitcoinannotated.com</span>
  </footer>
</BaseLayout>

<style>
  .filter-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    padding: 18px 0 24px;
    margin-bottom: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .filter-chip {
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.12s;
  }
  .filter-chip:hover { color: var(--orange); }
  .filter-chip.active { color: var(--orange); font-weight: 700; }
  .filter-chip .count {
    font-size: 9px;
    opacity: 0.55;
    margin-left: 3px;
    letter-spacing: 0.1em;
  }
  .filter-sep { color: var(--ink-faint); opacity: 0.4; }
  .index-row.filtered-out, .era-divider.filtered-out { display: none; }
</style>

<script>
  function applyFilter() {
    const params = new URLSearchParams(window.location.search);
    const filter = (params.get('type') || 'all').toLowerCase();

    document.querySelectorAll('.filter-chip').forEach((el) => {
      el.classList.toggle('active', el.dataset.type === filter);
    });

    const rows = document.querySelectorAll('.index-row');
    rows.forEach((row) => {
      const eraEl = row.querySelector('.era');
      const rowType = eraEl ? eraEl.textContent.trim().toLowerCase() : '';
      if (filter === 'all' || rowType === filter) {
        row.classList.remove('filtered-out');
      } else {
        row.classList.add('filtered-out');
      }
    });

    // Hide dividers (year or letter) with no visible rows beneath
    document.querySelectorAll('.sort-mode').forEach(mode => {
      const dividers = mode.querySelectorAll('.era-divider, .letter-divider');
      dividers.forEach((divider) => {
        let hasVisible = false;
        let next = divider.nextElementSibling;
        while (next && !next.classList.contains('era-divider') && !next.classList.contains('letter-divider')) {
          if (next.classList.contains('index-row') && !next.classList.contains('filtered-out') && !next.classList.contains('search-hidden')) {
            hasVisible = true;
            break;
          }
          next = next.nextElementSibling;
        }
        divider.classList.toggle('filtered-out', !hasVisible);
      });
    });
  }

  document.querySelectorAll('.filter-chip').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const type = el.dataset.type;
      const params = new URLSearchParams(window.location.search);
      if (type === 'all') params.delete('type');
      else params.set('type', type);
      const qs = params.toString();
      const url = qs ? `?${qs}` : window.location.pathname;
      history.pushState({}, '', url);
      applyFilter();
      document.querySelector('.sort-mode.active')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  window.addEventListener('popstate', () => { applyFilter(); applySort(); });
  applyFilter();
</script>

<style>
  .search-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .catalog-search-input {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    padding: 0.5rem 0;
    width: 320px;
    max-width: 100%;
    color: inherit;
    outline: none;
    transition: border-color 0.15s ease;
  }
  .catalog-search-input:focus { border-bottom-color: #d97706; }
  .catalog-search-input::placeholder {
    color: rgba(0, 0, 0, 0.35);
    letter-spacing: 0.05em;
  }
  .search-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #d97706;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .search-count.active { opacity: 1; }
  .index-row.search-hidden,
  .era-divider.search-hidden,
  .letter-divider.search-hidden { display: none; }
</style>

<script is:inline>
  (function() {
    function applySearch() {
      const input = document.getElementById('catalog-search');
      const countEl = document.getElementById('search-count');
      if (!input || !countEl) return;
      const q = input.value.trim().toLowerCase();
      const activeMode = document.querySelector('.sort-mode.active');
      if (!activeMode) return;
      const rows = activeMode.querySelectorAll('.index-row');
      const dividers = activeMode.querySelectorAll('.era-divider, .letter-divider');

      if (!q) {
        rows.forEach(el => el.classList.remove('search-hidden'));
        dividers.forEach(d => d.classList.remove('search-hidden'));
        countEl.classList.remove('active');
        countEl.textContent = '';
        return;
      }
      const tokens = q.split(/\s+/).filter(Boolean);
      let matches = 0;
      rows.forEach(el => {
        const text = el.getAttribute('data-search') || '';
        const hit = tokens.every(t => text.includes(t));
        const chipPass = !el.classList.contains('filtered-out');
        el.classList.toggle('search-hidden', !hit);
        if (hit && chipPass) matches++;
      });
      dividers.forEach(divider => {
        let next = divider.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('era-divider') && !next.classList.contains('letter-divider')) {
          if (next.classList.contains('index-row')
              && !next.classList.contains('search-hidden')
              && !next.classList.contains('filtered-out')) {
            hasVisible = true;
            break;
          }
          next = next.nextElementSibling;
        }
        divider.classList.toggle('search-hidden', !hasVisible);
      });
      const noun = matches === 1 ? 'ARTIFACT MATCHES' : 'ARTIFACTS MATCH';
      countEl.textContent = matches + ' ' + noun;
      countEl.classList.add('active');
    }

    function applySort() {
      const params = new URLSearchParams(window.location.search);
      const sort = params.get('sort') === 'name' ? 'name' : 'date';
      document.querySelectorAll('.sort-mode').forEach(el => {
        el.classList.toggle('active', el.dataset.sortMode === sort);
      });
      document.querySelectorAll('.sort-toggle .opt').forEach(el => {
        el.classList.toggle('active', el.dataset.sort === sort);
      });
    }

    document.querySelectorAll('.sort-toggle .opt').forEach(opt => {
      opt.addEventListener('click', function() {
        const sort = this.dataset.sort;
        const params = new URLSearchParams(window.location.search);
        if (sort === 'date') params.delete('sort');
        else params.set('sort', sort);
        const qs = params.toString();
        const url = qs ? `?${qs}` : window.location.pathname;
        history.pushState({}, '', url);
        applySort();
        applySearch();
      });
    });

    const input = document.getElementById('catalog-search');
    if (input) input.addEventListener('input', applySearch);

    window.addEventListener('popstate', () => { applySort(); applySearch(); });

    // Initial state
    applySort();
    applySearch();
    // Expose for the chip script (which may run separately) so chips can re-trigger search
    window.__applySearch = applySearch;
  })();
</script>
