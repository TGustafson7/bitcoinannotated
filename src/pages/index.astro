---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allEntries = await getCollection('entries');
allEntries.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
// group by year
const grouped: { year: number; entries: typeof allEntries }[] = [];
for (const entry of allEntries) {
  const year = entry.data.date.getUTCFullYear();
  const existing = grouped.find(g => g.year === year);
  if (existing) {
    existing.entries.push(entry);
  } else {
    grouped.push({ year, entries: [entry] });
  }
}
// type counts for filter chips
const typeCounts: Record<string, number> = { Phrase: 0, Event: 0, Iconography: 0, Document: 0 };
for (const entry of allEntries) {
  const t = entry.data.type;
  if (t in typeCounts) typeCounts[t]++;
}
const formatDate = (date: Date) => new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC'
}).format(date);

// Build a slug -> stripped-lowercase-body map for client-side full-text search
const bodyTextBySlug: Record<string, string> = {};
for (const entry of allEntries) {
  const raw = entry.body || '';
  const stripped = raw
    .replace(/```[\s\S]*?```/g, ' ')        // code fences
    .replace(/`[^`]*`/g, ' ')                 // inline code
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ') // images
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // links keep label
    .replace(/[#>*_~`]+/g, ' ')               // markdown punctuation
    .replace(/\s+/g, ' ')                    // collapse whitespace
    .trim()
    .toLowerCase();
  bodyTextBySlug[entry.slug] = stripped;
}

---
<BaseLayout>
  <section style="margin-bottom: 24px;">
    <h1 style="font-family: var(--display); font-size: clamp(40px, 4.4vw, 56px); line-height: 1.05; letter-spacing: -0.025em; font-weight: 500; margin-bottom: 14px;">
      An annotated archive of bitcoin's <em style="font-style: italic; color: var(--orange);">cultural artifacts.</em>
    </h1>
    <p style="font-family: var(--display); font-style: italic; font-size: 20px; color: var(--ink-mid); margin-bottom: 18px; text-wrap: balance;">
      The memes, phrases, events, and iconography that built bitcoin culture. Researched, sourced, dated, annotated.
    </p>
    <hr style="margin-top: 28px; border: 0; border-top: 1px solid var(--ink-mid); opacity: 0.2;" />
  </section>
  <div class="search-row">
  <input
    type="search"
    id="catalog-search"
    class="catalog-search-input"
    placeholder={`SEARCH ${allEntries.length} ARTIFACTS`}
    autocomplete="off"
    spellcheck="false"
  />
  <span class="search-count" id="search-count" aria-live="polite"></span>
</div>

  <nav class="filter-row" aria-label="Filter catalog by type">
    <a href="?type=all" class="filter-chip" data-type="all">ALL <span class="count">{allEntries.length}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=phrase" class="filter-chip" data-type="phrase">PHRASE <span class="count">{typeCounts.Phrase}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=event" class="filter-chip" data-type="event">EVENT <span class="count">{typeCounts.Event}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=iconography" class="filter-chip" data-type="iconography">ICONOGRAPHY <span class="count">{typeCounts.Iconography}</span></a>
    <span class="filter-sep">·</span>
    <a href="?type=document" class="filter-chip" data-type="document">DOCUMENT <span class="count">{typeCounts.Document}</span></a>
  </nav>
  <div class="index-list">
    {grouped.map((group) => (
      <>
        <div class="era-divider">{group.year}</div>
        {group.entries.map((entry) => (
          <a href={`/entries/${entry.slug}`} class="index-row" data-search={`${entry.data.title} ${entry.data.deck || ''} ${bodyTextBySlug[entry.slug] || ''}`.toLowerCase()}>
            <span class="id">{formatDate(entry.data.date)}</span>
            <span class="title">{entry.data.title}</span>
            <span class="era">{entry.data.type}</span>
            <span class="status">{entry.data.foundational ? '★' : ''}</span>
          </a>
        ))}
      </>
    ))}
  </div>
  <footer class="entry-footer" style="margin-top: 80px;">
    <span>{allEntries.length} entries · refreshed weekly</span>
    <span>bitcoinannotated.com</span>
  </footer>
</BaseLayout>

<style>
  .filter-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
    flex-wrap: wrap;
    padding: 18px 0 24px;
    margin-bottom: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .filter-chip {
    color: var(--ink-mid);
    text-decoration: none;
    transition: color 0.12s;
  }
  .filter-chip:hover {
    color: var(--orange);
  }
  .filter-chip.active {
    color: var(--orange);
    font-weight: 700;
  }
  .filter-chip .count {
    font-size: 9px;
    opacity: 0.55;
    margin-left: 3px;
    letter-spacing: 0.1em;
  }
  .filter-sep {
    color: var(--ink-faint);
    opacity: 0.4;
  }
  .index-row.filtered-out, .era-divider.filtered-out {
    display: none;
  }
</style>

<script>
  function applyFilter() {
    const params = new URLSearchParams(window.location.search);
    const filter = (params.get('type') || 'all').toLowerCase();

    // Set active chip
    document.querySelectorAll('.filter-chip').forEach((el) => {
      el.classList.toggle('active', el.dataset.type === filter);
    });

    // Filter rows by their type span
    const rows = document.querySelectorAll('.index-row');
    rows.forEach((row) => {
      const eraEl = row.querySelector('.era');
      const rowType = eraEl ? eraEl.textContent.trim().toLowerCase() : '';
      if (filter === 'all' || rowType === filter) {
        row.classList.remove('filtered-out');
      } else {
        row.classList.add('filtered-out');
      }
    });

    // Hide era dividers that have no visible rows after them (until next divider)
    const all = Array.from(document.querySelectorAll('.era-divider, .index-row'));
    const dividers = document.querySelectorAll('.era-divider');
    dividers.forEach((divider) => {
      let hasVisible = false;
      let next = divider.nextElementSibling;
      while (next && !next.classList.contains('era-divider')) {
        if (next.classList.contains('index-row') && !next.classList.contains('filtered-out')) {
          hasVisible = true;
          break;
        }
        next = next.nextElementSibling;
      }
      divider.classList.toggle('filtered-out', !hasVisible);
    });
  }

  // Run on load + when chips clicked (intercept to update URL without full reload)
  document.querySelectorAll('.filter-chip').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const type = el.dataset.type;
      const url = type === 'all' ? window.location.pathname : `?type=${type}`;
      history.pushState({}, '', url);
      applyFilter();
      // scroll to top of catalog smoothly so filtered list is visible
      document.querySelector('.index-list')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // Handle back/forward buttons
  window.addEventListener('popstate', applyFilter);

  // Apply on initial load
  applyFilter();
</script>

<style>
  .search-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .catalog-search-input {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    padding: 0.5rem 0;
    width: 320px;
    max-width: 100%;
    color: inherit;
    outline: none;
    transition: border-color 0.15s ease;
  }
  .catalog-search-input:focus { border-bottom-color: #d97706; }
  .catalog-search-input::placeholder {
    color: rgba(0, 0, 0, 0.35);
    letter-spacing: 0.05em;
  }
  .search-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #d97706;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .search-count.active { opacity: 1; }
  /* Search hides via the same mechanism chip filtering uses, so they compose */
  .index-row.search-hidden,
  .era-divider.search-hidden { display: none; }
</style>

<script is:inline>
  (function() {
    const input = document.getElementById('catalog-search');
    const countEl = document.getElementById('search-count');
    if (!input || !countEl) return;

    const rows = document.querySelectorAll('.index-row');
    const dividers = document.querySelectorAll('.era-divider');
    const indexed = Array.from(rows).map(row => ({
      el: row,
      text: row.getAttribute('data-search') || ''
    }));

    function apply(query) {
      const q = query.trim().toLowerCase();
      if (!q) {
        indexed.forEach(({ el }) => el.classList.remove('search-hidden'));
        dividers.forEach(d => d.classList.remove('search-hidden'));
        countEl.classList.remove('active');
        countEl.textContent = '';
        return;
      }
      const tokens = q.split(/\s+/).filter(Boolean);
      let matches = 0;
      indexed.forEach(({ el, text }) => {
        const hit = tokens.every(t => text.includes(t));
        // Only count rows that ALSO pass the chip filter (not filtered-out)
        const chipPass = !el.classList.contains('filtered-out');
        el.classList.toggle('search-hidden', !hit);
        if (hit && chipPass) matches++;
      });
      // Hide era dividers whose visible-by-both-filters children are zero
      dividers.forEach(divider => {
        let next = divider.nextElementSibling;
        let hasVisible = false;
        while (next && !next.classList.contains('era-divider')) {
          if (next.classList.contains('index-row')
              && !next.classList.contains('search-hidden')
              && !next.classList.contains('filtered-out')) {
            hasVisible = true;
            break;
          }
          next = next.nextElementSibling;
        }
        divider.classList.toggle('search-hidden', !hasVisible);
      });
      const noun = matches === 1 ? 'ARTIFACT MATCHES' : 'ARTIFACTS MATCH';
      countEl.textContent = matches + ' ' + noun;
      countEl.classList.add('active');
    }

    input.addEventListener('input', e => apply(e.target.value));
  })();
</script>

