---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEntries = await getCollection('entries');
allEntries.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

// group by era
const eraOrder = ['Genesis', 'First Bull', 'Dark Forest', '2017 Run', 'Crypto Winter', 'DeFi/Covid', 'Institutional Entry', 'Frauds', 'Institutional Takeover', 'Now'];
const grouped = {};
for (const era of eraOrder) grouped[era] = [];
for (const entry of allEntries) grouped[entry.data.era].push(entry);
---

<BaseLayout>
  <section style="margin-bottom: 56px;">
    <h1 style="font-family: var(--display); font-size: clamp(48px, 6vw, 72px); line-height: 1; letter-spacing: -0.025em; font-weight: 500; margin-bottom: 18px;">
      An annotated archive of bitcoin's <em style="font-style: italic; color: var(--orange);">cultural artifacts.</em>
    </h1>
    <p style="font-family: var(--display); font-style: italic; font-size: 22px; color: var(--ink-mid); max-width: 720px;">
      The memes, phrases, events, and iconography that built bitcoin culture. Researched, sourced, dated, annotated.
    </p>
  </section>

  <div class="index-list">
    {eraOrder.map((era) => grouped[era].length > 0 && (
      <>
        <div class="era-divider">{era}</div>
        {grouped[era].map((entry) => (
          <a href={`/entries/${entry.slug}`} class="index-row">
            <span class="id">{entry.data.catalogId}</span>
            <span class="title">{entry.data.title}</span>
            <span class="era">{entry.data.type}</span>
            <span class="status">{entry.data.status}</span>
          </a>
        ))}
      </>
    ))}
  </div>

  <footer class="entry-footer" style="margin-top: 80px;">
    <span>{allEntries.length} entries · refreshed weekly</span>
    <span>bitcoinannotated.com</span>
  </footer>
</BaseLayout>
