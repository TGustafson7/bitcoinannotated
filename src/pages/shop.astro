---
import BaseLayout from '../layouts/BaseLayout.astro';

const prints = [
  { slug: 'bitcoin-is-dead',      title: 'Bitcoin is Dead',      deck: 'Hundreds of obituaries. Still alive.' },
  { slug: 'the-offering',         title: 'The Offering',         deck: 'Satoshi gave it away and disappeared.' },
  { slug: 'bitcoin-not-crypto',   title: 'Bitcoin Not Crypto',   deck: 'There is no second best.' },
  { slug: 'tick-tock-next-block', title: 'Tick-tock, next block', deck: 'Timechain. A block every ten minutes, without pause.' },
];
---
<BaseLayout title="Shop" description="Fine-art prints drawn from the catalog — coming soon.">
  <section class="shop">
    <header class="shop-header">
      <p class="shop-eyebrow">The Shop &middot; Coming Soon</p>
      <h1>The <em>Prints</em></h1>
      <p class="shop-deck">
        Four works drawn from the catalog's own hand. Giclée on 100% cotton rag &mdash;
        a signed, hand-numbered limited edition.
      </p>

      <form class="notify" action="https://buttondown.com/api/emails/embed-subscribe/bitcoinannotated" method="post" target="_blank">
        <input type="email" name="email" required placeholder="you@email.com" aria-label="Email address" />
        <input type="hidden" name="embed" value="1" />
        <button type="submit">Notify me &rarr;</button>
      </form>
      <p class="notify-done" hidden>On the list &mdash; we'll email you when the shop opens.</p>
    </header>

    <div class="print-grid">
      {prints.map((p) => (
        <figure class="print-card">
          <div class="print-frame">
            <img src={`/images/prints/ba-${p.slug}.png`} alt={p.title} loading="lazy" width="900" height="1200" />
            <span class="print-badge">Coming soon</span>
          </div>
          <figcaption>
            <b>{p.title}</b>
            <span class="print-deck">{p.deck}</span>
            <span class="print-status">18 &times; 24 in &middot; Limited edition</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="shop-foot">
      Prices and ordering open once the first proofs are in hand. Bitcoin only.
    </p>
  </section>

  <script is:inline>
    (function () {
      var form = document.querySelector('.notify');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        fetch(form.action, { method: 'POST', mode: 'no-cors', body: new URLSearchParams(new FormData(form)) }).catch(function () {});
        form.hidden = true;
        var done = document.querySelector('.notify-done');
        if (done) done.hidden = false;
      });
    })();
  </script>
</BaseLayout>

<style>
  .shop {
    max-width: 1000px;
    margin: 64px auto 96px;
    padding: 0 24px;
  }
  .shop-header {
    max-width: 720px;
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid #d8cfb8;
  }
  .shop-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #d97706;
    margin: 0 0 18px;
  }
  .shop h1 {
    font-family: 'EB Garamond', serif;
    font-size: clamp(48px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    font-weight: 500;
    margin: 0 0 18px;
    color: #1a1a1a;
  }
  .shop h1 em {
    font-style: italic;
    color: #d97706;
    font-weight: 400;
  }
  .shop-deck {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 22px;
    line-height: 1.45;
    color: #4a4a4a;
    margin: 0 0 28px;
  }

  .notify {
    display: flex;
    gap: 10px;
    max-width: 460px;
    flex-wrap: wrap;
  }
  .notify input[type="email"] {
    flex: 1 1 220px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: #1a1a1a;
    background: transparent;
    border: 1.5px solid #d8cfb8;
    padding: 11px 14px;
  }
  .notify input[type="email"]:focus {
    outline: none;
    border-color: #1a1a1a;
  }
  .notify button {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #1a1a1a;
    background: transparent;
    border: 1.5px solid #1a1a1a;
    padding: 11px 22px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .notify button:hover {
    background: #d97706;
    border-color: #d97706;
    color: #f8f4ed;
  }
  .notify-done {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: #d97706;
    margin: 0;
  }

  .print-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 44px;
  }
  .print-card {
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .print-frame {
    position: relative;
    background: #f2ece0;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.22);
  }
  .print-frame img {
    display: block;
    width: 100%;
    height: auto;
  }
  .print-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #f8f4ed;
    background: #1a1a1a;
    padding: 5px 10px;
  }
  .print-card figcaption {
    margin-top: 20px;
    text-align: center;
  }
  .print-card b {
    display: block;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 500;
    font-size: 24px;
    color: #1a1a1a;
  }
  .print-deck {
    display: block;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.45;
    color: #5c564d;
    margin: 7px auto 0;
    max-width: 320px;
  }
  .print-status {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #9b9484;
    margin-top: 12px;
  }

  .shop-foot {
    margin: 72px auto 0;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: #6b6358;
  }

  @media (max-width: 720px) {
    .print-grid {
      grid-template-columns: 1fr;
      gap: 44px;
    }
  }
</style>
