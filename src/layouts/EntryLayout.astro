---
import BaseLayout from './BaseLayout.astro';
const { entry } = Astro.props;
const { data } = entry;
const formattedDate = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' }).format(data.date);
const formatBlockHeight = (bh: number | string | undefined) => {
  if (bh === undefined) return null;
  if (bh === 'Pre-chain') return 'PRE-CHAIN';
  return `BLOCK ${bh.toLocaleString('en-US')}`;
};
const blockHeightDisplay = formatBlockHeight(data.blockHeightAtOrigin);
// Resolve the primary source — the artifact itself, as opposed to corroborating context.
// Annotated-edition logic: the catalog frames; the primary source IS the thing being framed.
// Convention: explicit `primary: true` flag wins. No flag → no primary link is shown.
const primarySource = data.sources?.find((s) => s.primary);

// JSON-LD Article schema for search/AI retrieval.
// Editorial register is anonymous-collective, so author is omitted; publisher is the catalog.
const canonical = new URL(`/entries/${entry.slug}`, Astro.site).href;
const heroImageUrl = data.heroImage ? new URL(data.heroImage, Astro.site).href : undefined;
const isoDate = new Date(data.date).toISOString();
const citations = (data.sources ?? []).map((s) => ({
  "@type": "CreativeWork",
  name: s.label,
  url: s.url,
}));
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.title,
  description: data.deck,
  datePublished: isoDate,
  dateModified: isoDate,
  inLanguage: "en",
  isAccessibleForFree: true,
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  url: canonical,
  ...(heroImageUrl && { image: heroImageUrl }),
  publisher: {
    "@type": "Organization",
    name: "The Bitcoin Annotated",
    url: "https://bitcoinannotated.com",
  },
  ...(citations.length > 0 && { citation: citations }),
  about: {
    "@type": "Thing",
    name: "Bitcoin",
  },
  articleSection: data.era,
  keywords: [data.type, data.era, "bitcoin", "cultural artifact"].join(", "),
};
---
<BaseLayout title={data.title} description={data.deck} image={data.heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <div class="catalog-bar">
    <span>{data.era.toUpperCase()}</span>
    {data.foundational && <span>FOUNDATIONAL</span>}
    <span>
      {blockHeightDisplay && <><span class="bh">{blockHeightDisplay}</span> · </>}
      {formattedDate.toUpperCase()}
    </span>
  </div>
  <section class="hero">
    <div class="hero-text">
      <div class="hero-kicker">{data.type}</div>
      <h1>{data.title}</h1>
      {data.pronunciation && <div class="pronunciation">{data.pronunciation}</div>}
      <div class="deck">{data.deck}</div>
    </div>
    <aside class="meta-card">
      <div class="meta-row">
        <span class="meta-label">Origin</span>
        <span class="meta-value">
          {blockHeightDisplay && <><span class="bh-meta">{blockHeightDisplay}</span><br/></>}
          <span class={blockHeightDisplay ? 'origin-date' : ''}>{formattedDate}</span>
        </span>
      </div>
      {data.creator && <div class="meta-row"><span class="meta-label">Creator</span><span class={`meta-value ${data.locked ? 'locked' : ''}`}>{data.creator}</span></div>}
      {data.sourcePlatform && <div class="meta-row"><span class="meta-label">Source</span><span class="meta-value">{data.sourcePlatform}</span></div>}
      <div class="meta-row"><span class="meta-label">Era</span><span class="meta-value">{data.era}</span></div>
      <div class="meta-row"><span class="meta-label">Type</span><span class="meta-value">{data.type}</span></div>
      {data.foundational && <div class="meta-row"><span class="meta-label">Foundational</span><span class="meta-value">Yes</span></div>}
      {data.btcPriceAtOrigin && <div class="meta-row"><span class="meta-label">BTC at origin</span><span class="meta-value">{data.btcPriceAtOrigin}</span></div>}
    </aside>
  </section>
  {data.heroImage && (
    <figure class="hero-image">
      <img src={data.heroImage} alt={data.heroImageCaption || data.title} loading="lazy" />
      {(data.heroImageCaption || data.heroImageCredit) && (
        <figcaption>
          {data.heroImageCaption && <span class="caption-text">{data.heroImageCaption}</span>}
          {data.heroImageCredit && <span class="caption-credit">{data.heroImageCredit}</span>}
        </figcaption>
      )}
    </figure>
  )}
  {primarySource && (
    <div class={`primary-source ${data.heroImage ? 'has-hero' : 'no-hero'}`}>
      <span class="primary-source-label">View the original artifact</span>
      <a href={primarySource.url} class="primary-source-link" target="_blank" rel="noopener">
        → {primarySource.label}
      </a>
    </div>
  )}
  <article class={`prose ${data.foundational ? "foundational" : ""}`}>
    <slot />
  </article>
  {data.sources && data.sources.length > 0 && (
    <section class="receipts">
      <h2 style="font-family: var(--display); font-size: 24px; margin-top: 64px; margin-bottom: 18px; font-weight: 500;"><em style="color: var(--orange); font-style: italic;">Receipts</em></h2>
      <ul style="list-style: none; font-family: var(--mono); font-size: 13px; line-height: 1.8;">
        {data.sources.map((s) => (
          <li>→ <a href={s.url}>{s.label}</a></li>
        ))}
      </ul>
    </section>
  )}
  <footer class="entry-footer">
    <span>Edition 1 · Last revised {formattedDate}</span>
    <a href="https://x.com/BTCannotated" target="_blank" rel="noopener" class="suggest-correction">Suggest a correction →</a>
  </footer>
</BaseLayout>
<style>
  .catalog-bar .bh { color: #d97706; font-weight: 600; }
  .meta-card .bh-meta { color: #d97706; font-weight: 600; letter-spacing: 0.04em; font-size: 12px; }
  .meta-card .origin-date { color: #6b6358; font-size: 13px; font-style: italic; }
  .hero-image { margin: 48px auto 56px; max-width: 720px; }
  .hero-image img { width: 100%; height: auto; max-height: 620px; object-fit: contain; display: block; border: 1px solid #d8cfb8; background: #f0eadd; }
  .hero-image figcaption { margin-top: 14px; font-family: 'JetBrains Mono', monospace; font-size: 11px; line-height: 1.6; color: #6b6358; letter-spacing: 0.02em; display: flex; flex-direction: column; gap: 2px; }
  .hero-image .caption-text { color: #4a4a4a; }
  .hero-image .caption-credit { font-style: italic; opacity: 0.7; }
  /* PRIMARY SOURCE — annotated-edition link to the artifact itself */
  .primary-source {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 56px;
    padding: 18px 24px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
    text-align: center;
  }
  .primary-source.has-hero { margin-top: -32px; }
  .primary-source.no-hero { margin-top: 16px; }
  .primary-source-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .primary-source-link {
    font-family: 'EB Garamond', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    color: var(--orange-deep);
    text-decoration-color: rgba(217, 119, 6, 0.25);
  }
  .primary-source-link:hover { text-decoration-color: var(--orange); }
  .suggest-correction {
    color: inherit;
    text-decoration: none;
    transition: color 0.12s ease;
  }
  .suggest-correction:hover {
    color: #d97706;
  }
</style>
