---
import '../styles/global.css';
const { title, description, image } = Astro.props;
const fullTitle = title ? `${title} — The Bitcoin Annotated` : 'The Bitcoin Annotated';
const fullDescription = description ?? "An annotated archive of bitcoin's cultural artifacts.";
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageSrc = image
  ? (image.endsWith('.svg') ? image.replace('/images/entries/', '/images/og/').replace('.svg', '.png') : image)
  : '/og-default.png';
const ogImage = new URL(ogImageSrc, Astro.site).href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={fullDescription} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="The Bitcoin Annotated" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={fullDescription} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={fullDescription} />
  <meta name="twitter:image" content={ogImage} />
</head>
<body>
  <div class="page-wrap">
    <header class="topbar">
      <a href="/" class="brand">The Bitcoin <em>Annotated</em></a>
      <nav>
        <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Catalog</a>
        <a href="/timeline" class={Astro.url.pathname === '/timeline' ? 'active' : ''}>Timechain</a>
        <a href="/about" class={Astro.url.pathname === '/about' ? 'active' : ''}>About</a>
      </nav>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-col footer-col--brand">
          <div class="footer-brand">The Bitcoin <em>Annotated</em></div>
          <p class="footer-tag">A reference work for bitcoin's cultural artifacts.</p>
        </div>
        <div class="footer-col">
          <div class="footer-label">Browse</div>
          <a href="/">Catalog</a>
          <a href="/timeline">Timechain</a>
          <a href="/about">About</a>
        </div>
        <div class="footer-col">
          <div class="footer-label">Editorial</div>
          <span class="footer-stance">No advertising</span>
          <span class="footer-stance">No sponsorships</span>
          <span class="footer-stance">No trading advice</span>
          <span class="footer-stance">Bitcoin only</span>
          <a class="footer-stance footer-handle" href="https://x.com/BTCannotated" target="_blank" rel="noopener">@BTCannotated</a>
        </div>
      </div>
      <div class="footer-rule"></div>
      <div class="footer-meta">
        <span>The Bitcoin Annotated · Published anonymously</span>
        <span class="footer-meta-right">An archive in progress.</span>
      </div>
    </footer>
  </div>
</body>

<style is:global>
  .site-footer {
    margin-top: 120px;
    padding: 56px 24px 40px;
    background: transparent;
    border-top: 1px solid #d8cfb8;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-brand {
    font-family: 'EB Garamond', serif;
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: #1a1a1a;
    margin-bottom: 8px;
  }
  .footer-brand em {
    font-style: italic;
    color: #d97706;
    font-weight: 400;
  }
  .footer-tag {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.45;
    color: #6b6358;
    max-width: 340px;
    margin: 0;
  }
  .footer-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9b9484;
    margin-bottom: 6px;
  }
  .footer-col a {
    font-family: 'EB Garamond', serif;
    font-size: 16px;
    color: #2a2a2a;
    text-decoration: none;
    transition: color 0.12s ease;
  }
  .footer-col a:hover {
    color: #d97706;
  }
  .footer-stance {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #6b6358;
  }
  .footer-handle {
    text-decoration: none;
    transition: color 0.12s ease;
  }
  .footer-handle:hover {
    color: #d97706;
  }
  .footer-rule {
    max-width: 1100px;
    margin: 48px auto 0;
    height: 1px;
    background: #ebe3d2;
  }
  .footer-meta {
    max-width: 1100px;
    margin: 20px auto 0;
    display: flex;
    justify-content: space-between;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: #9b9484;
  }
  .footer-meta-right {
    font-style: italic;
  }
  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .footer-meta {
      flex-direction: column;
      gap: 6px;
    }
  }
</style>
</html>
