<svg width="100%" viewBox="0 0 1210 760" xmlns="http://www.w3.org/2000/svg" role="img" style=""><title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Hyperbitcoinization hero image</title><desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Typography-forward hero image: the word HYPERBITCOINIZATION set in serif italic on cream background, with bitcoin-orange accent on the prefix HYPER, attribution to Daniel Krawisz 2014 below.</desc>

<rect x="0" y="0" width="1200" height="750" fill="#f5efe1" style="fill:rgb(245, 239, 225);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<rect x="0" y="0" width="1200" height="2" fill="#1a1a1a" opacity="0.08" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.08;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<rect x="0" y="748" width="1200" height="2" fill="#1a1a1a" opacity="0.08" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.08;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<text x="80" y="120" font-family="Georgia, 'Times New Roman', serif" font-size="13" letter-spacing="3" fill="#1a1a1a" opacity="0.55" font-weight="500" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.55;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:13px;font-weight:500;text-anchor:start;dominant-baseline:auto">PHRASE · THE LONG WAIT · 2014</text>

<text x="80" y="148" font-family="Georgia, 'Times New Roman', serif" font-size="13" letter-spacing="2" fill="#c9740c" font-weight="500" font-style="italic" style="fill:rgb(201, 116, 12);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:13px;font-weight:500;font-style:italic;text-anchor:start;dominant-baseline:auto">Daniel Krawisz · Satoshi Nakamoto Institute</text>

<text x="600" y="430" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-style="italic" font-size="118" font-weight="400" letter-spacing="-2" style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:118px;font-weight:400;font-style:italic;text-anchor:middle;dominant-baseline:auto">
<tspan fill="#c9740c" style="fill:rgb(201, 116, 12);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:118px;font-weight:400;font-style:italic;text-anchor:middle;dominant-baseline:auto">Hyper</tspan><tspan fill="#1a1a1a" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:118px;font-weight:400;font-style:italic;text-anchor:middle;dominant-baseline:auto">bitcoinization.</tspan>
</text>

<line x1="350" y1="510" x2="850" y2="510" stroke="#1a1a1a" stroke-width="0.5" opacity="0.2" style="fill:rgb(0, 0, 0);stroke:rgb(26, 26, 26);color:rgb(0, 0, 0);stroke-width:0.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.2;font-family:&quot;Anthropic Sans&quot;, -apple-system, &quot;system-ui&quot;, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<text x="600" y="570" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-style="italic" font-size="22" fill="#1a1a1a" opacity="0.7" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.7;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:22px;font-weight:400;font-style:italic;text-anchor:middle;dominant-baseline:auto">
Bitcoin-induced currency demonetization.
</text>

<text x="80" y="700" font-family="Georgia, 'Times New Roman', serif" font-size="12" letter-spacing="2" fill="#1a1a1a" opacity="0.5" font-weight="500" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:12px;font-weight:500;text-anchor:start;dominant-baseline:auto">MARCH 29, 2014</text>

<text x="1120" y="700" text-anchor="end" font-family="Georgia, 'Times New Roman', serif" font-size="12" letter-spacing="2" fill="#1a1a1a" opacity="0.5" font-weight="500" style="fill:rgb(26, 26, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:12px;font-weight:500;text-anchor:end;dominant-baseline:auto">BITCOIN ANNOTATED</text>

</svg>